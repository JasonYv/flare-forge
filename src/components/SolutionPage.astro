---
/**
 * Reusable industry / application solution page template.
 * Builds: hero → pain points → recommended product section (pulled from Content Collection) → CTA.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

interface Props {
  industrySlug: string;
  metaTitle: string;
  metaDescription: string;
  heroEyebrow: string;
  heroTitle: string;
  heroSubtitle: string;
  heroImage: string;
  painPointsHeading: string;
  painPoints: { icon?: string; title: string; description: string }[];
  recommendedCategory: string; // category slug to pull products from
  recommendedHeading?: string;
  recommendedSubtitle?: string;
  caseStudyTeaser?: { title: string; body: string; metric?: string };
}

const {
  industrySlug,
  metaTitle,
  metaDescription,
  heroEyebrow,
  heroTitle,
  heroSubtitle,
  heroImage,
  painPointsHeading,
  painPoints,
  recommendedCategory,
  recommendedHeading = 'Recommended Models',
  recommendedSubtitle,
  caseStudyTeaser,
} = Astro.props as Props;

const allProducts = await getCollection('products', ({ data }) => !data.draft);
const recommended = allProducts
  .filter((p) => p.data.category === recommendedCategory)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: metaTitle,
  description: metaDescription,
  url: `${siteConfig.url}/solutions/${industrySlug}`,
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: siteConfig.url },
};
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={heroImage} jsonLd={jsonLd}>
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li><a href="/solutions" class="hover:text-steel">Applications</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">{heroTitle}</li>
      </ol>
    </div>
  </nav>

  <header class="relative w-full h-[480px] flex items-center bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={heroTitle} class="w-full h-full object-cover opacity-85" width="2000" height="1000" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand-dark/30 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-screen-2xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl">
        <p class="text-brand-gold font-mono text-xs tracking-[0.2em] uppercase mb-5 pl-3 border-l-2 border-brand-gold">{heroEyebrow}</p>
        <h1 class="text-white text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">{heroTitle}</h1>
        <p class="text-[#bbc7df] text-lg md:text-xl font-light leading-relaxed">{heroSubtitle}</p>
      </div>
    </div>
  </header>

  <!-- Pain points -->
  <section class="bg-white py-20">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-steel mb-3">Why It Matters</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark tracking-tight">{painPointsHeading}</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {painPoints.map((p) => (
          <div class="bg-cold-white p-8 border-l-4 border-steel">
            {p.icon && (
              <span class="material-symbols-outlined text-steel mb-4 block" style="font-size:36px">{p.icon}</span>
            )}
            <h3 class="text-lg font-bold text-brand-dark mb-3">{p.title}</h3>
            <p class="text-sm text-neutral-gray leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recommended Products -->
  {recommended.length > 0 && (
    <section class="bg-cold-white py-20">
      <div class="max-w-screen-xl mx-auto px-6 md:px-10">
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-steel mb-3">Recommended For This Application</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark tracking-tight">{recommendedHeading}</h2>
            {recommendedSubtitle && <p class="text-neutral-gray mt-3 max-w-2xl">{recommendedSubtitle}</p>}
          </div>
          <a href={`/products/${recommendedCategory}`} class="text-sm font-bold uppercase tracking-widest text-brand-gold hover:text-brand-dark transition-colors inline-flex items-center gap-2">
            All Models in Series
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {recommended.map((p) => (
            <a href={`/products/${p.id}`} class="group bg-white border border-light-steel rounded-sm overflow-hidden hover:shadow-lg hover:border-steel transition-all">
              <div class="aspect-square bg-cold-white p-8 flex items-center justify-center">
                <img src={p.data.images[0]} alt={`${p.data.altusvoltSku} ${p.data.title}`} class="object-contain w-full h-full transition-transform duration-500 group-hover:scale-105" width="400" height="400" loading="lazy" />
              </div>
              <div class="p-6 border-t border-light-steel">
                <p class="text-[10px] font-bold uppercase tracking-widest text-steel mb-2">{p.data.altusvoltSku}</p>
                <h3 class="text-lg font-bold text-brand-dark mb-2 group-hover:text-steel transition-colors">{p.data.title}</h3>
                <div class="flex flex-wrap gap-2 text-xs">
                  <span class="bg-cold-white px-2 py-1 rounded font-mono"><strong>{p.data.capacityAh}Ah</strong></span>
                  {p.data.ccaA && <span class="bg-cold-white px-2 py-1 rounded font-mono"><strong>{p.data.ccaA}A</strong> CCA</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Case study teaser -->
  {caseStudyTeaser && (
    <section class="bg-white py-20">
      <div class="max-w-4xl mx-auto px-6 md:px-10">
        <div class="bg-brand-dark text-white p-8 md:p-12 rounded-sm relative overflow-hidden">
          <p class="text-brand-gold font-mono text-xs tracking-[0.2em] uppercase mb-4">Case Study Teaser</p>
          <h3 class="text-2xl md:text-3xl font-bold mb-4">{caseStudyTeaser.title}</h3>
          <p class="text-[#bbc7df] leading-relaxed mb-6">{caseStudyTeaser.body}</p>
          {caseStudyTeaser.metric && (
            <div class="text-3xl font-mono font-bold text-brand-gold border-t border-white/10 pt-6">
              {caseStudyTeaser.metric}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-brand-dark py-16">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="text-white text-3xl font-bold mb-2">Need an application-specific spec?</h2>
        <p class="text-[#bbc7df]">Tell us your fleet, vehicle list, or system load. Engineers respond within 24 hours.</p>
      </div>
      <a href={`/quote?ref=${industrySlug}`} class="bg-brand-gold text-brand-dark px-8 py-4 font-bold text-sm tracking-widest uppercase rounded-sm hover:brightness-110 transition shrink-0">
        Request Quote
      </a>
    </div>
  </section>
</BaseLayout>
