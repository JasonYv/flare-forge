---
import { siteConfig } from '../config';
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark w-full border-t border-slate-800">
  <div class="grid grid-cols-2 md:grid-cols-6 gap-8 md:gap-12 px-6 md:px-10 py-16 w-full max-w-screen-2xl mx-auto">
    <!-- Brand block (spans 2 cols on md) -->
    <div class="col-span-2">
      <a href="/" class="inline-block mb-4" aria-label={siteConfig.name}>
        <img src="/images/brand/logo-dark.webp" alt={siteConfig.name} class="h-7 w-auto" width="240" height="60" />
      </a>
      <p class="text-sm leading-relaxed text-slate-400 mb-4">
        Global Export Partner for Lingyun Battery — overseas sales and OEM coordination, backed by 30+ years of IATF 16949 manufacturing.
      </p>
      <p class="text-xs text-slate-500 leading-relaxed mb-4">
        IATF 16949 · ISO 9001/14001/45001 · CCS · CE
      </p>
      <a href={`mailto:${siteConfig.contact.email}`} class="text-sm text-brand-gold font-mono hover:text-white transition-colors">
        {siteConfig.contact.email}
      </a>
    </div>

    <!-- Products -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-xs uppercase tracking-wider">Products</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/products/agm-batteries/" class="text-slate-400 hover:text-brand-gold transition-colors">AGM Batteries</a></li>
        <li><a href="/products/efb-batteries/" class="text-slate-400 hover:text-brand-gold transition-colors">EFB Batteries</a></li>
        <li><a href="/products/heavy-duty-batteries/" class="text-slate-400 hover:text-brand-gold transition-colors">Heavy-Duty Batteries</a></li>
        <li><a href="/products/marine-batteries/" class="text-slate-400 hover:text-brand-gold transition-colors">Marine Batteries</a></li>
        <li><a href="/products/" class="text-brand-gold hover:text-white transition-colors">View all →</a></li>
      </ul>
    </div>

    <!-- Solutions -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-xs uppercase tracking-wider">Solutions</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/distributor-program/" class="text-slate-400 hover:text-brand-gold transition-colors">Distributor Program</a></li>
        <li><a href="/oem-private-label/" class="text-slate-400 hover:text-brand-gold transition-colors">OEM / Private Label</a></li>
        <li><a href="/markets/australia/" class="text-slate-400 hover:text-brand-gold transition-colors">Australia Market</a></li>
      </ul>
    </div>

    <!-- Support / Company -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-xs uppercase tracking-wider">Support & Company</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/support/agm-vs-efb/" class="text-slate-400 hover:text-brand-gold transition-colors">AGM vs EFB</a></li>
        <li><a href="/support/battery-standards/" class="text-slate-400 hover:text-brand-gold transition-colors">Battery Standards</a></li>
        <li><a href="/factory-and-certifications/" class="text-slate-400 hover:text-brand-gold transition-colors">Factory & Certifications</a></li>
        <li><a href="/about-altusvolt/" class="text-slate-400 hover:text-brand-gold transition-colors">About AltusVolt</a></li>
        <li><a href="/brand/lingyun-battery/" class="text-slate-400 hover:text-brand-gold transition-colors">The Lingyun Brand</a></li>
        <li><a href="/contact/" class="text-slate-400 hover:text-brand-gold transition-colors">Contact</a></li>
      </ul>
    </div>

    <!-- Quote CTA -->
    <div>
      <h4 class="text-white font-semibold mb-4 text-xs uppercase tracking-wider">Get Started</h4>
      <a href="/distributor-program/" class="block bg-brand-gold text-brand-dark px-4 py-3 text-center font-bold text-xs tracking-widest uppercase rounded-sm hover:brightness-110 transition mb-3">
        Request Quote
      </a>
      <p class="text-xs text-slate-500 leading-relaxed">
        Reply within 24 hours.<br />
        OEM / Private Label welcome.
      </p>
    </div>
  </div>

  <!-- Address bar -->
  <div class="border-t border-slate-800/50 py-6 px-6 md:px-10">
    <div class="max-w-screen-2xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-3 text-xs text-slate-500">
      <p class="leading-relaxed">
        Manufacturing partner: <span class="text-slate-400">{siteConfig.manufacturingPartner.name}</span> &middot; {siteConfig.contact.address}
      </p>
      <ul class="flex items-center gap-5">
        <li><a href="/terms" class="hover:text-brand-gold transition-colors">Terms</a></li>
        <li><a href="/privacy" class="hover:text-brand-gold transition-colors">Privacy</a></li>
        <li>&copy; {year} AltusVolt. All rights reserved.</li>
      </ul>
    </div>
  </div>
</footer>
