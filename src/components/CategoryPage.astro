---
/**
 * Reusable category landing page template.
 * Pulls products for a given category from the Content Collection,
 * renders a hero + product grid + RFQ CTA.
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';

interface Props {
  /** Single category slug, or array for multi-category roll-ups */
  categorySlug: string | string[];
  /** Public URL for this landing page (used in breadcrumbs + JSON-LD). Defaults to /products/<slug>. */
  categoryUrl?: string;
  /** Display name override (used when slug-based lookup is ambiguous, e.g. multi-category) */
  categoryName?: string;
  heroTitle: string;
  heroSubtitle: string;
  heroEyebrow?: string;
  heroImage: string;
  introHeading: string;
  introBody: string;
  features?: { icon?: string; title: string; description: string }[];
  comingSoonNote?: string;
  metaTitle: string;
  metaDescription: string;
  /** Big category cover image (LINGYUN-branded product photo) shown alongside spec table */
  categoryImage?: string;
  /** Heading for the spec table block. Defaults to "Available Specifications". */
  specTableHeading?: string;
}

const {
  categorySlug,
  categoryUrl,
  categoryName: categoryNameProp,
  heroTitle,
  heroSubtitle,
  heroEyebrow,
  heroImage,
  introHeading,
  introBody,
  features = [],
  comingSoonNote,
  metaTitle,
  metaDescription,
  categoryImage,
  specTableHeading = 'Available Specifications',
} = Astro.props as Props;

const slugList = Array.isArray(categorySlug) ? categorySlug : [categorySlug];
const primarySlug = slugList[0];

const allProducts = await getCollection('products', ({ data }) => !data.draft);
const products = allProducts
  .filter((p) => slugList.includes(p.data.category))
  .sort((a, b) => a.data.order - b.data.order);

const category = siteConfig.productCategories.find((c) => c.slug === primarySlug);
const categoryName = categoryNameProp ?? category?.name ?? primarySlug;
const resolvedUrl = categoryUrl ?? `/products/${primarySlug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: metaTitle,
  description: metaDescription,
  url: `${siteConfig.url}${resolvedUrl}`,
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: siteConfig.url },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: products.length,
    itemListElement: products.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Product',
        name: `${p.data.model} ${p.data.title}`,
        sku: p.data.altusvoltSku,
        manufacturer: { '@type': 'Organization', name: 'Shaanxi Lingyun Storage Battery Co., Ltd.' },
      },
    })),
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${siteConfig.url}/products` },
    { '@type': 'ListItem', position: 3, name: categoryName, item: `${siteConfig.url}${resolvedUrl}` },
  ],
};
---

<BaseLayout title={metaTitle} description={metaDescription} ogImage={heroImage} jsonLd={jsonLd}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <!-- Breadcrumb -->
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li><a href="/products" class="hover:text-steel">Products</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">{categoryName}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <header class="relative w-full h-[480px] flex items-center bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt={heroTitle} class="w-full h-full object-cover opacity-85" width="2000" height="1000" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand-dark/30 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-screen-2xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl">
        {heroEyebrow && (
          <p class="text-brand-gold font-mono text-xs tracking-[0.2em] uppercase mb-5 pl-3 border-l-2 border-brand-gold">
            {heroEyebrow}
          </p>
        )}
        <h1 class="text-white text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">{heroTitle}</h1>
        <p class="text-[#bbc7df] text-lg md:text-xl font-light leading-relaxed">{heroSubtitle}</p>
      </div>
    </div>
  </header>

  <!-- Intro -->
  <section class="bg-white py-20">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl">
        <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark mb-6 tracking-tight">{introHeading}</h2>
        <p class="text-neutral-700 text-lg leading-relaxed">{introBody}</p>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  {features.length > 0 && (
    <section class="bg-cold-white py-16">
      <div class="max-w-screen-xl mx-auto px-6 md:px-10">
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {features.map((f) => (
            <div class="bg-white p-6 rounded-sm border border-light-steel">
              {f.icon && (
                <span class="material-symbols-outlined text-steel mb-4 block" style="font-size:32px">
                  {f.icon}
                </span>
              )}
              <h3 class="text-base font-semibold text-brand-dark mb-2">{f.title}</h3>
              <p class="text-sm text-neutral-gray leading-relaxed">{f.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cover Image + Spec Table -->
  <section class="bg-white py-20">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="grid lg:grid-cols-5 gap-12 items-start">
        {categoryImage && (
          <div class="lg:col-span-2">
            <div class="bg-cold-white p-8 lg:p-10 rounded-sm border border-light-steel sticky top-24">
              <img src={categoryImage} alt={categoryName} class="w-full h-auto object-contain" loading="lazy" width="800" height="600" />
              <p class="text-[10px] font-mono uppercase tracking-widest text-neutral-500 mt-6 text-center border-t border-light-steel pt-4">
                Lingyun-manufactured · IATF 16949
              </p>
            </div>
          </div>
        )}

        <div class={categoryImage ? 'lg:col-span-3' : 'lg:col-span-5'}>
          <p class="text-xs font-bold uppercase tracking-widest text-steel mb-2">{specTableHeading}</p>
          <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark tracking-tight mb-3">{categoryName}</h2>
          <p class="text-neutral-gray leading-relaxed mb-8 text-sm">
            The full {categoryName.toLowerCase()} range manufactured by Lingyun and exported by AltusVolt. Custom capacities, dimensions, and labels available — talk to our export team for any spec not listed below.
          </p>

          {products.length === 0 ? (
            <div class="bg-cold-white border border-light-steel p-8 rounded-sm">
              <p class="text-neutral-gray text-sm">Specifications shipping shortly. Contact <a href="/contact" class="text-steel font-bold hover:underline">our export team</a> for the full datasheet PDF.</p>
            </div>
          ) : (
            <div class="overflow-x-auto border border-light-steel rounded-sm">
              <table class="w-full text-sm text-left">
                <thead class="bg-cold-white text-[10px] uppercase tracking-wider text-steel font-bold">
                  <tr>
                    <th class="px-4 py-3 border-b border-light-steel">Lingyun Model</th>
                    <th class="px-4 py-3 border-b border-light-steel text-right">Voltage</th>
                    <th class="px-4 py-3 border-b border-light-steel text-right">Capacity</th>
                    <th class="px-4 py-3 border-b border-light-steel text-right">CCA</th>
                    <th class="px-4 py-3 border-b border-light-steel text-right">RC</th>
                    <th class="px-4 py-3 border-b border-light-steel">Dimensions (L×W×H mm)</th>
                    <th class="px-4 py-3 border-b border-light-steel text-right">Weight</th>
                  </tr>
                </thead>
                <tbody>
                  {products.map((p) => (
                    <tr class="hover:bg-cold-white/60 transition-colors">
                      <td class="px-4 py-3 border-b border-light-steel font-mono text-brand-dark font-semibold">{p.data.model}</td>
                      <td class="px-4 py-3 border-b border-light-steel text-right font-mono">{p.data.voltage}</td>
                      <td class="px-4 py-3 border-b border-light-steel text-right font-mono">{p.data.capacityAh} Ah</td>
                      <td class="px-4 py-3 border-b border-light-steel text-right font-mono">{p.data.ccaA ? `${p.data.ccaA} A` : '—'}</td>
                      <td class="px-4 py-3 border-b border-light-steel text-right font-mono">{p.data.rcMin ? `${p.data.rcMin} min` : '—'}</td>
                      <td class="px-4 py-3 border-b border-light-steel font-mono text-xs">{p.data.lengthMm && p.data.widthMm && p.data.heightMm ? `${p.data.lengthMm}×${p.data.widthMm}×${p.data.heightMm}` : '—'}</td>
                      <td class="px-4 py-3 border-b border-light-steel text-right font-mono">{p.data.weightKg ? `${p.data.weightKg} kg` : '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          <p class="text-xs text-neutral-500 mt-4 italic">
            Need a model not listed? Lingyun's tooling supports custom case dimensions, electrical specs, and private labels. <a href="/oem-private-label/" class="text-steel font-bold hover:underline">OEM project inquiry →</a>
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/distributor-program/" class="inline-flex items-center gap-2 bg-brand-gold text-brand-dark px-6 py-3 font-bold text-xs tracking-widest uppercase rounded-sm hover:brightness-110 transition">
              Request Distributor Quote
            </a>
            <a href="/oem-private-label/" class="inline-flex items-center gap-2 bg-white border border-steel text-steel px-6 py-3 font-bold text-xs tracking-widest uppercase rounded-sm hover:bg-cold-white transition">
              OEM / Private Label
            </a>
          </div>

          {comingSoonNote && (
            <p class="text-center text-neutral-gray mt-12 text-sm italic">{comingSoonNote}</p>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-dark py-16">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10 flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h2 class="text-white text-3xl font-bold mb-2">Ready to source from the factory?</h2>
        <p class="text-[#bbc7df]">Custom OEM/ODM, private label, and bulk container pricing available.</p>
      </div>
      <a href="/distributor-program" class="bg-brand-gold text-brand-dark px-8 py-4 font-bold text-sm tracking-widest uppercase rounded-sm hover:brightness-110 transition shrink-0">
        Request Quote
      </a>
    </div>
  </section>
</BaseLayout>
