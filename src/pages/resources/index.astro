---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';

const kbArticles = await getCollection('kb', ({ data }) => !data.draft);
kbArticles.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

let newsArticles: { id: string; data: { title: string; summary: string; publishedAt: Date } }[] = [];
try {
  const news = await getCollection('news', ({ data }) => !data.draft);
  newsArticles = news.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()).slice(0, 4);
} catch {}

const sections = [
  {
    title: 'Knowledge Base',
    icon: 'menu_book',
    description: 'Technology comparisons, sizing calculators, shipping compliance, and cross-reference tables for purchasing engineers.',
    href: '/resources/knowledge-base',
    cta: `${kbArticles.length} articles`,
  },
  {
    title: 'News & Insights',
    icon: 'newspaper',
    description: 'Industry analysis on the global lead-acid battery market, certifications, and AltusVolt company updates.',
    href: '/news',
    cta: `${newsArticles.length} recent`,
  },
  {
    title: 'Certification Library',
    icon: 'verified',
    description: 'IATF 16949, ISO 9001/14001/45001, CCS, and CNAS certificates for vendor onboarding and customs documentation.',
    href: '/resources/certifications',
    cta: 'Browse certs',
  },
  {
    title: 'Downloads Center',
    icon: 'download',
    description: 'Technical datasheets, MSDS, UN2794 declarations, packing lists, and certificate PDFs.',
    href: '/resources/downloads',
    cta: 'Datasheets & MSDS',
  },
  {
    title: 'Shipping Compliance',
    icon: 'local_shipping',
    description: 'IMDG / IATA / ADR documentation, UN2794 / UN2800 classification, container packing certificates.',
    href: '/resources/shipping',
    cta: 'Read guide',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AltusVolt Resources Center',
  description: 'Technical guides, certifications, datasheets, news, and shipping compliance documentation for AltusVolt batteries.',
  url: `${siteConfig.url}/resources`,
};
---

<BaseLayout
  title="Resources — Knowledge Base, Certifications, Downloads, News"
  description="AltusVolt resources for purchasing engineers and distributors: technical knowledge base, certification library, datasheet downloads, industry news, and shipping compliance documentation."
  jsonLd={jsonLd}
>
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">Resources</li>
      </ol>
    </div>
  </nav>

  <header class="relative w-full min-h-[400px] flex items-center bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero/hero-equipment.webp" alt="Resources" class="w-full h-full object-cover opacity-85" width="2000" height="1000" fetchpriority="high" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand-dark/30 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-screen-2xl mx-auto px-6 md:px-10 py-16">
      <div class="max-w-3xl">
        <p class="text-brand-gold font-mono text-xs tracking-[0.2em] uppercase mb-5 pl-3 border-l-2 border-brand-gold">
          Resources
        </p>
        <h1 class="text-white text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">
          Documentation for buyers who do their homework.
        </h1>
        <p class="text-[#bbc7df] text-lg md:text-xl font-light leading-relaxed">
          Knowledge base, certification PDFs, technical datasheets, industry analysis, and shipping compliance — everything purchasing engineers and aftermarket distributors need to evaluate, source, and resell AltusVolt batteries.
        </p>
      </div>
    </div>
  </header>

  <section class="bg-white py-20">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sections.map((s) => (
          <a href={s.href} class="group bg-cold-white border border-light-steel p-8 hover:bg-white hover:border-steel hover:shadow-md transition-all">
            <span class="material-symbols-outlined text-steel mb-4 block group-hover:text-brand-gold transition-colors" style="font-size:36px">
              {s.icon}
            </span>
            <h2 class="text-xl font-bold text-brand-dark mb-3">{s.title}</h2>
            <p class="text-sm text-neutral-gray leading-relaxed mb-6">{s.description}</p>
            <div class="flex items-center justify-between border-t border-light-steel pt-4">
              <span class="text-[10px] font-mono uppercase tracking-widest text-neutral-500">{s.cta}</span>
              <svg class="w-4 h-4 text-steel group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {kbArticles.length > 0 && (
    <section class="bg-cold-white py-20">
      <div class="max-w-screen-xl mx-auto px-6 md:px-10">
        <div class="flex items-end justify-between mb-12 flex-wrap gap-4">
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-steel mb-3">Featured Reading</p>
            <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark tracking-tight">Recent guides & comparisons.</h2>
          </div>
          <a href="/resources/knowledge-base" class="text-sm font-bold uppercase tracking-widest text-brand-gold hover:text-brand-dark transition-colors inline-flex items-center gap-2">
            All Articles
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {kbArticles.slice(0, 3).map((article) => (
            <a href={`/resources/knowledge-base/${article.id}`} class="group bg-white border border-light-steel p-6 hover:shadow-md hover:border-steel transition-all">
              <p class="text-[10px] font-bold uppercase tracking-widest text-steel mb-3">{article.data.category}</p>
              <h3 class="text-lg font-bold text-brand-dark mb-3 group-hover:text-steel transition-colors leading-snug">{article.data.title}</h3>
              <p class="text-sm text-neutral-gray leading-relaxed line-clamp-3">{article.data.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
