---
/**
 * Downloads Center — request real PDFs (datasheets, MSDS, certificates) via lead-capture form.
 *
 * Strategy: We don't expose direct PDF URLs to anonymous visitors — instead we collect
 * the buyer's email + company + intended use, then deliver the requested PDF bundle
 * by email. This keeps the documentation database clean and gives sales attribution.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { siteConfig } from '../../config';

const docBundles = [
  {
    slug: 'product-datasheet-bundle',
    icon: 'description',
    title: 'Full Product Datasheet Bundle',
    description: '18-model technical specifications across all 8 categories: electrical specs, dimensions, terminal layouts, cycle life data, and certification scope.',
    contents: ['AGM Start-Stop datasheets (5 models)', 'EFB Start-Stop (5 models)', 'Heavy-Duty Truck (5 models)', 'Solar / Marine / Parking AC datasheets'],
    sizeApprox: '~12 MB · 65 pages',
  },
  {
    slug: 'certification-bundle',
    icon: 'verified',
    title: 'Certification Bundle',
    description: 'IATF 16949, ISO 9001/14001/45001, CCS Type Approval, CNAS Lab Accreditation, GB/T national standards. For vendor onboarding and customs documentation.',
    contents: ['IATF 16949 certificate (English)', 'ISO 9001/14001/45001 certificates', 'CCS Type Approval (Marine)', 'GB/T national standard mappings'],
    sizeApprox: '~6 MB · 12 PDFs',
  },
  {
    slug: 'msds-shipping-bundle',
    icon: 'local_shipping',
    title: 'MSDS / Shipping Compliance Bundle',
    description: 'Material Safety Data Sheets (16-section GHS format), UN2794/UN2800 declarations, IMDG packing certificates, and per-country compliance notes.',
    contents: ['MSDS (English, latest revision)', 'UN2794 / UN2800 declarations', 'IMDG container packing certificate', 'Country-specific notes (EU REACH, etc.)'],
    sizeApprox: '~4 MB · 8 PDFs',
  },
  {
    slug: 'cross-reference-table',
    icon: 'compare_arrows',
    title: 'Cross-Reference Lookup Table',
    description: 'AltusVolt model equivalents to Varta, Bosch, Exide, Yuasa, GS Yuasa, Panasonic, Banner, ACDelco, Trojan, Optima, Mastervolt, Lifeline, Ritar.',
    contents: ['JIS aftermarket cross-references', 'DIN / EN heavy-duty references', 'AGM start-stop OE replacements', 'Marine and solar deep-cycle equivalents'],
    sizeApprox: '~2 MB · Excel + PDF',
  },
  {
    slug: 'oem-odm-program-deck',
    icon: 'factory',
    title: 'OEM/ODM Program Deck',
    description: 'Private-label and ODM partnership program details: MOQ tiers, tooling investment, lead times, payment terms, and case studies.',
    contents: ['Private-label MOQ from 1 container', 'Custom case dimensions process', 'Lead time schedule (sample → production)', 'Sample case studies'],
    sizeApprox: '~5 MB · 24 pages',
  },
  {
    slug: 'company-brochure',
    icon: 'business',
    title: 'AltusVolt Company Brochure',
    description: 'Full company introduction including manufacturing partner Lingyun factory, equipment lines, certifications, and global export footprint.',
    contents: ['Factory & equipment overview', 'Quality system summary', 'Global export footprint', 'Trust and certification matrix'],
    sizeApprox: '~10 MB · 32 pages',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AltusVolt Downloads Center',
  description: 'Datasheets, MSDS, certifications, cross-reference tables, and shipping documentation for AltusVolt batteries — delivered by email after request.',
  url: `${siteConfig.url}/resources/downloads`,
};
---

<BaseLayout
  title="Downloads Center — Datasheets, MSDS & Certificates"
  description="AltusVolt downloads center — request datasheet bundles, certification PDFs, MSDS, cross-reference tables, and OEM/ODM program decks. Delivered by email within 1 business day."
  jsonLd={jsonLd}
>
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li><a href="/resources" class="hover:text-steel">Resources</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">Downloads</li>
      </ol>
    </div>
  </nav>

  <header class="relative w-full min-h-[400px] flex items-center bg-brand-dark overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero/hero-equipment.webp" alt="" class="w-full h-full object-cover opacity-85" width="2000" height="1000" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand-dark/30 to-transparent"></div>
    </div>
    <div class="relative z-10 w-full max-w-screen-2xl mx-auto px-6 md:px-10 py-16">
      <div class="max-w-3xl">
        <p class="text-brand-gold font-mono text-xs tracking-[0.2em] uppercase mb-5 pl-3 border-l-2 border-brand-gold">Downloads Center</p>
        <h1 class="text-white text-4xl md:text-6xl font-bold tracking-tight leading-tight mb-6">Documentation, on demand.</h1>
        <p class="text-[#bbc7df] text-lg md:text-xl font-light leading-relaxed">
          Request the bundle that matches your evaluation stage. Engineers email back within one business day with the latest versions — including any country-specific compliance addenda you flag.
        </p>
      </div>
    </div>
  </header>

  <section class="bg-white py-20">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="mb-10 max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-widest text-steel mb-3">Available Bundles</p>
        <h2 class="text-3xl md:text-4xl font-semibold text-brand-dark tracking-tight mb-4">Choose what you need.</h2>
        <p class="text-neutral-700 leading-relaxed">
          We deliver documentation by email rather than direct download — gives us a chance to pair you with the right application engineer and to attach country-specific compliance notes for your target market.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {docBundles.map((bundle) => (
          <div class="bg-cold-white border border-light-steel p-7 hover:bg-white hover:border-steel hover:shadow-md transition-all flex flex-col">
            <span class="material-symbols-outlined text-steel mb-4 block" style="font-size:36px">{bundle.icon}</span>
            <h3 class="text-lg font-bold text-brand-dark mb-3">{bundle.title}</h3>
            <p class="text-sm text-neutral-gray leading-relaxed mb-4">{bundle.description}</p>
            <ul class="text-xs text-neutral-gray space-y-1 mb-5 border-l-2 border-light-steel pl-3">
              {bundle.contents.map((c) => (<li>· {c}</li>))}
            </ul>
            <p class="text-[10px] font-mono uppercase tracking-widest text-neutral-500 mb-5">{bundle.sizeApprox}</p>
            <a
              href={`/quote?ref=download-${bundle.slug}`}
              class="mt-auto bg-brand-gold text-brand-dark px-5 py-3 font-bold text-xs tracking-widest uppercase rounded-sm hover:brightness-110 transition text-center"
            >
              Request Bundle
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Email-only quick request -->
  <section class="bg-cold-white py-16">
    <div class="max-w-2xl mx-auto px-6 md:px-10 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-dark mb-4">Looking for a specific document?</h2>
      <p class="text-neutral-700 mb-8">
        If you need a datasheet for a specific model not covered by these bundles, email us directly with the model number and target country.
      </p>
      <a href={`mailto:${siteConfig.contact.email}?subject=Datasheet%20Request&body=Model%20number%3A%20%0AApplication%3A%20%0ATarget%20country%3A%20%0ACompany%3A%20`} class="inline-flex items-center gap-2 bg-brand-dark text-white px-8 py-3 font-bold text-sm tracking-widest uppercase rounded-sm hover:brightness-110 transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Email a Specific Request
      </a>
    </div>
  </section>
</BaseLayout>
