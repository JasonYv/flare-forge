---
/**
 * Global Certifications — Battery certifications for global markets with regional compliance details.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Battery Certifications for Global Markets"
  description="Navigate international battery regulations with precision. Essential compliance frameworks for deploying industrial energy storage systems across EU, MEA, and APAC regions."
>
  <div class="w-full bg-[#f7f9fc] min-h-screen text-[#191c1e]">
    <div class="flex-grow w-full max-w-[1440px] mx-auto px-6 md:px-12 py-16 flex flex-col gap-24">

      <!-- Hero Section: Editorial Statement -->
      <header class="flex flex-col gap-6 max-w-4xl">
        <div class="flex items-center gap-4">
          <div class="w-1 h-6 bg-[#436086]"></div>
          <span class="text-sm uppercase tracking-widest text-[#436086] font-bold">Global Compliance Hub</span>
        </div>
        <h1 class="text-4xl md:text-[3.5rem] leading-[1.1] tracking-tight text-[#101c2e] font-bold">
          Battery Certifications for Global Markets
        </h1>
        <p class="text-[#45474c] text-lg max-w-2xl font-medium leading-relaxed">
          Navigating the complex landscape of international battery regulations requires precision. This guide details the essential compliance frameworks necessary for deploying high-grade industrial energy storage systems across key global regions.
        </p>
      </header>

      <!-- Global Map Visual Anchor -->
      <section class="w-full bg-white p-8 relative isolate overflow-hidden shadow-sm rounded-sm border border-[#e0e3e6]">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
          <h2 class="text-2xl text-[#436086] font-bold tracking-tight">Global Distribution Standards</h2>
          <div class="font-mono text-sm text-[#75777d] flex gap-4 font-medium">
            <span>UPDT: 2024.11.15</span>
            <span>VER: 4.2.1</span>
          </div>
        </div>

        <!-- Conceptual Map Area -->
        <div class="w-full h-[300px] md:h-[500px] bg-[#e0e3e6]/50 rounded-sm relative overflow-hidden flex items-center justify-center border border-[#e0e3e6]">
          <img
            src="/images/hero/hero-certifications.webp"
            alt="Global Map"
            class="w-full h-full object-cover opacity-20 mix-blend-luminosity grayscale"
          />

          <!-- Overlay Data Points -->
          <div class="absolute inset-0 p-4 md:p-12 flex flex-col justify-between pointer-events-none">

            <!-- Data Point EU -->
            <div class="absolute top-[20%] md:top-[30%] left-[30%] md:left-[45%] flex flex-col items-start gap-2">
              <div class="w-3 h-3 bg-[#c7a850] rounded-full shadow-[0_0_12px_rgba(199,168,80,0.6)]"></div>
              <div class="bg-[#101c2e] border border-[#e4c368] px-3 py-1.5 flex flex-col gap-1 rounded-sm">
                <span class="text-[10px] text-white tracking-widest font-bold uppercase">REGION: EU</span>
                <span class="font-mono text-[#e4c368] text-xs font-bold">CE / ROHS / REACH</span>
              </div>
            </div>

            <!-- Data Point MEA -->
            <div class="absolute top-[50%] md:top-[55%] left-[45%] md:left-[52%] flex flex-col items-start gap-2">
              <div class="w-3 h-3 bg-[#436086] rounded-full"></div>
              <div class="bg-white border border-[#c5c6cd] px-3 py-1.5 flex flex-col gap-1 shadow-sm rounded-sm text-left">
                <span class="text-[10px] text-[#191c1e] tracking-widest font-bold uppercase">REGION: MEA</span>
                <span class="font-mono text-[#436086] text-xs font-bold">SASO / SONCAP</span>
              </div>
            </div>

            <!-- Data Point APAC -->
            <div class="absolute top-[40%] md:top-[45%] left-[65%] md:left-[75%] flex flex-col items-start gap-2">
              <div class="w-3 h-3 bg-[#436086] rounded-full"></div>
              <div class="bg-white border border-[#c5c6cd] px-3 py-1.5 flex flex-col gap-1 shadow-sm rounded-sm text-left">
                <span class="text-[10px] text-[#191c1e] tracking-widest font-bold uppercase">REGION: APAC</span>
                <span class="font-mono text-[#436086] text-xs font-bold">BIS / PSE / KC</span>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- Regional Specifications Bento Grid -->
      <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Europe Card -->
        <article class="bg-white p-8 flex flex-col gap-8 shadow-sm border border-[#e0e3e6] rounded-sm transition-all hover:shadow-md hover:border-[#c7a850]">
          <div class="flex items-center gap-3">
            <div class="w-1 h-6 bg-[#c7a850]"></div>
            <h3 class="text-xl font-bold text-[#191c1e]">Europe</h3>
          </div>

          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">Primary Certification</span>
              <div class="flex items-center justify-between border-b border-[#e0e3e6] pb-3 mt-1">
                <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">CE MARKING</span>
                <span class="material-symbols-outlined text-[#c7a850] text-2xl">check_circle</span>
              </div>
              <p class="text-sm text-[#45474c] leading-relaxed mt-2 font-medium">Mandatory conformity mark for products sold within the European Economic Area (EEA).</p>
            </div>

            <div class="flex flex-col gap-3 mt-4">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">Material Compliance</span>
              <div class="flex gap-2">
                <div class="bg-[#101c2e] border border-[#e4c368] px-2.5 py-1.5 rounded-sm">
                  <span class="text-[10px] text-white tracking-widest font-bold uppercase">ROHS 2.0</span>
                </div>
                <div class="bg-[#101c2e] border border-[#e4c368] px-2.5 py-1.5 rounded-sm">
                  <span class="text-[10px] text-white tracking-widest font-bold uppercase">REACH</span>
                </div>
              </div>
            </div>
          </div>
        </article>

        <!-- Middle East & Africa Card -->
        <article class="bg-white p-8 flex flex-col gap-8 shadow-sm border border-[#e0e3e6] rounded-sm transition-all hover:shadow-md hover:border-[#436086]">
          <div class="flex items-center gap-3">
            <div class="w-1 h-6 bg-[#436086]"></div>
            <h3 class="text-xl font-bold text-[#191c1e]">Middle East & Africa</h3>
          </div>

          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">Saudi Arabia</span>
              <div class="flex items-center justify-between border-b border-[#e0e3e6] pb-3 mt-1">
                <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">SASO</span>
                <span class="material-symbols-outlined text-[#436086] text-2xl">description</span>
              </div>
              <p class="text-sm text-[#45474c] leading-relaxed mt-2 font-medium">Saudi Standards, Metrology and Quality Organization certification for market entry.</p>
            </div>

            <div class="flex flex-col gap-2 mt-4">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">Nigeria</span>
              <div class="flex items-center justify-between border-b border-[#e0e3e6] pb-3 mt-1">
                <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">SONCAP</span>
                <span class="material-symbols-outlined text-[#436086] text-2xl">description</span>
              </div>
              <p class="text-sm text-[#45474c] leading-relaxed mt-2 font-medium">Standards Organisation of Nigeria Conformity Assessment Program.</p>
            </div>
          </div>
        </article>

        <!-- Asia Pacific Card -->
        <article class="bg-white p-8 flex flex-col gap-8 shadow-sm border border-[#e0e3e6] rounded-sm transition-all hover:shadow-md hover:border-[#436086]">
          <div class="flex items-center gap-3">
            <div class="w-1 h-6 bg-[#436086]"></div>
            <h3 class="text-xl font-bold text-[#191c1e]">Asia Pacific</h3>
          </div>

          <div class="flex flex-col gap-6">
            <div class="flex flex-col gap-2">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">India</span>
              <div class="flex items-center justify-between border-b border-[#e0e3e6] pb-3 mt-1">
                <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">BIS</span>
                <span class="material-symbols-outlined text-[#436086] text-2xl">assignment_turned_in</span>
              </div>
              <p class="text-sm text-[#45474c] leading-relaxed mt-2 font-medium">Bureau of Indian Standards certification, mandatory for specific battery chemistries.</p>
            </div>

            <div class="flex flex-col gap-3 mt-4">
              <span class="text-xs uppercase tracking-widest text-[#75777d] font-bold">Other Key Markets</span>
              <div class="flex flex-wrap gap-2">
                <div class="bg-[#f2f4f7] border border-[#e0e3e6] px-3 py-1.5 rounded-sm">
                  <span class="font-mono text-xs text-[#45474c] font-bold">PSE (Japan)</span>
                </div>
                <div class="bg-[#f2f4f7] border border-[#e0e3e6] px-3 py-1.5 rounded-sm">
                  <span class="font-mono text-xs text-[#45474c] font-bold">KC (South Korea)</span>
                </div>
              </div>
            </div>
          </div>
        </article>

      </section>

      <!-- EU Timeline Graphic -->
      <section class="bg-[#f2f4f7] p-8 md:p-12 rounded-sm border border-[#e0e3e6]">
        <header class="flex flex-col gap-2 mb-16">
          <h2 class="text-2xl text-[#101c2e] font-bold tracking-tight">EU Battery Regulation Timeline</h2>
          <p class="text-[#45474c] text-sm max-w-xl font-medium">Critical implementation phases for the new European regulatory framework regarding sustainability and lifecycle management.</p>
        </header>

        <div class="relative flex flex-col md:flex-row justify-between items-start gap-12 md:gap-4">

          <!-- Connecting Line (Desktop) -->
          <div class="hidden md:block absolute top-[24px] left-8 right-[10%] h-0.5 bg-[#e0e3e6] -z-10"></div>

          <!-- Timeline Milestone 1 -->
          <div class="flex flex-col gap-6 relative w-full md:w-1/3 pr-4 md:pr-8">
            <div class="w-12 h-12 rounded-full bg-white border-2 border-[#c7a850] flex items-center justify-center z-10 shadow-sm">
              <span class="font-mono text-sm text-[#c7a850] font-bold">24</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">FEB 2024</span>
              <span class="text-[10px] text-[#c7a850] uppercase tracking-widest font-bold">Phase 1 Active</span>
              <p class="text-sm text-[#45474c] mt-2 border-l-2 border-[#c5c6cd] pl-4 font-medium">Application of general rules and carbon footprint declaration requirements for EV batteries.</p>
            </div>
          </div>

          <!-- Timeline Milestone 2 -->
          <div class="flex flex-col gap-6 relative w-full md:w-1/3 pr-4 md:pr-8">
            <div class="w-12 h-12 rounded-full bg-white border-2 border-[#c5c6cd] flex items-center justify-center z-10 shadow-sm">
              <span class="font-mono text-sm text-[#75777d] font-bold">25</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">AUG 2025</span>
              <span class="text-[10px] text-[#75777d] uppercase tracking-widest font-bold">Pending Compliance</span>
              <p class="text-sm text-[#45474c] mt-2 border-l-2 border-[#e0e3e6] pl-4 font-medium">Mandatory supply chain due diligence policies take effect for economic operators.</p>
            </div>
          </div>

          <!-- Timeline Milestone 3 -->
          <div class="flex flex-col gap-6 relative w-full md:w-1/3 pr-4">
            <div class="w-12 h-12 rounded-full bg-white border-2 border-[#c5c6cd] flex items-center justify-center z-10 shadow-sm">
              <span class="font-mono text-sm text-[#75777d] font-bold">27</span>
            </div>
            <div class="flex flex-col gap-2">
              <span class="font-mono text-lg text-[#101c2e] font-bold tracking-tight">FEB 2027</span>
              <span class="text-[10px] text-[#75777d] uppercase tracking-widest font-bold">Digital Passport</span>
              <p class="text-sm text-[#45474c] mt-2 border-l-2 border-[#e0e3e6] pl-4 font-medium">Implementation of the mandatory 'Battery Passport' containing detailed lifecycle data.</p>
            </div>
          </div>

        </div>
      </section>

    </div>
  </div>
</BaseLayout>
