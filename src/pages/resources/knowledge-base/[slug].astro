---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../config';

export async function getStaticPaths() {
  const articles = await getCollection('kb', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: article.data.title,
  description: article.data.summary,
  image: article.data.coverImage ? new URL(article.data.coverImage, siteConfig.url).href : undefined,
  datePublished: article.data.publishedAt.toISOString(),
  dateModified: (article.data.updatedAt ?? article.data.publishedAt).toISOString(),
  author: { '@type': 'Organization', name: 'AltusVolt Engineering' },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    logo: { '@type': 'ImageObject', url: `${siteConfig.url}/images/brand/logo-light.png` },
  },
  mainEntityOfPage: `${siteConfig.url}/resources/knowledge-base/${article.id}`,
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Resources', item: `${siteConfig.url}/resources` },
    { '@type': 'ListItem', position: 3, name: 'Knowledge Base', item: `${siteConfig.url}/resources/knowledge-base` },
    { '@type': 'ListItem', position: 4, name: article.data.title, item: `${siteConfig.url}/resources/knowledge-base/${article.id}` },
  ],
};
---

<BaseLayout
  title={article.data.title}
  description={article.data.summary}
  ogImage={article.data.coverImage}
  jsonLd={jsonLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li><a href="/resources/knowledge-base" class="hover:text-steel">Knowledge Base</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium truncate max-w-md">{article.data.title}</li>
      </ol>
    </div>
  </nav>

  <article class="py-12 lg:py-20">
    <div class="max-w-3xl mx-auto px-6 md:px-10">
      <header class="mb-10">
        <div class="flex items-center gap-3 text-sm text-neutral-500 mb-4">
          <time datetime={article.data.publishedAt.toISOString()}>
            {article.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="text-neutral-300">·</span>
          <span class="text-steel font-medium capitalize">{article.data.category}</span>
        </div>
        <h1 class="text-3xl sm:text-5xl font-bold text-brand-dark leading-tight tracking-tight">{article.data.title}</h1>
        <p class="mt-5 text-lg text-neutral-700">{article.data.summary}</p>
      </header>

      {article.data.coverImage && (
        <img
          src={article.data.coverImage}
          alt={article.data.title}
          class="w-full rounded-sm mb-10 aspect-[16/9] object-cover"
          width="1200"
          height="675"
          loading="eager"
          fetchpriority="high"
        />
      )}

      <div class="prose prose-lg max-w-none prose-headings:text-brand-dark prose-a:text-steel prose-table:text-sm">
        <Content />
      </div>

      <div class="mt-16 pt-8 border-t border-neutral-200 flex flex-wrap items-center justify-between gap-4">
        <a href="/resources/knowledge-base" class="text-steel font-medium hover:underline">&larr; Back to Knowledge Base</a>
        <a href="/distributor-program" class="bg-brand-gold text-brand-dark px-6 py-3 font-bold text-sm tracking-widest uppercase rounded-sm hover:brightness-110 transition">
          Request Quote
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
