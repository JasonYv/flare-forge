---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { siteConfig } from '../../../config';

const articles = await getCollection('kb', ({ data }) => !data.draft);
articles.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const categoryLabels: Record<string, string> = {
  guide: 'Buyer Guides',
  comparison: 'Technology Comparisons',
  shipping: 'Shipping & Compliance',
  sizing: 'Sizing & Calculation',
  reference: 'Reference Tables',
};

const categoryColors: Record<string, string> = {
  guide: 'bg-steel/10 text-steel',
  comparison: 'bg-brand-gold/10 text-brand-gold',
  shipping: 'bg-emerald-500/10 text-emerald-700',
  sizing: 'bg-purple-500/10 text-purple-700',
  reference: 'bg-blue-500/10 text-blue-700',
};

const grouped: Record<string, typeof articles> = {};
for (const a of articles) {
  const c = a.data.category;
  if (!grouped[c]) grouped[c] = [];
  grouped[c].push(a);
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AltusVolt Battery Knowledge Base',
  description: 'Technical guides, technology comparisons, sizing calculators, shipping compliance, and cross-reference tables for industrial lead-acid batteries.',
  url: `${siteConfig.url}/resources/knowledge-base`,
};
---

<BaseLayout
  title="Battery Knowledge Base — Technical Guides & References"
  description="Technical guides, technology comparisons, sizing calculators, shipping compliance, and cross-reference tables for industrial lead-acid batteries from AltusVolt."
  jsonLd={jsonLd}
>
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-steel">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li><a href="/resources" class="hover:text-steel">Resources</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">Knowledge Base</li>
      </ol>
    </div>
  </nav>

  <section class="bg-white py-16 lg:py-24">
    <div class="max-w-screen-xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-steel mb-3">Knowledge Base</p>
        <h1 class="text-4xl md:text-5xl font-semibold text-brand-dark mb-4 tracking-tight">
          Technical guides, comparisons & references for battery buyers.
        </h1>
        <p class="text-neutral-700 text-lg leading-relaxed">
          Practical, opinionated technical content for purchasing engineers, fleet managers, and aftermarket distributors. No fluff — just the math, decision frameworks, and reference tables we use internally.
        </p>
      </div>

      {Object.entries(grouped).map(([category, items]) => (
        <div class="mb-14">
          <div class="flex items-baseline gap-3 mb-6 border-b border-light-steel pb-3">
            <h2 class="text-xl font-bold text-brand-dark">{categoryLabels[category] ?? category}</h2>
            <span class={`text-[10px] font-bold uppercase tracking-widest px-2 py-0.5 rounded ${categoryColors[category] ?? 'bg-neutral-200 text-neutral-700'}`}>
              {items.length} article{items.length === 1 ? '' : 's'}
            </span>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {items.map((article) => (
              <a href={`/resources/knowledge-base/${article.id}`} class="group bg-white border border-light-steel rounded-sm p-6 hover:shadow-md hover:border-steel transition-all">
                <time class="text-xs text-neutral-500 font-mono mb-3 block">
                  {article.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
                <h3 class="text-lg font-bold text-brand-dark mb-3 group-hover:text-steel transition-colors leading-snug">
                  {article.data.title}
                </h3>
                <p class="text-sm text-neutral-gray leading-relaxed line-clamp-3 mb-4">
                  {article.data.summary}
                </p>
                {article.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1.5">
                    {article.data.tags.slice(0, 3).map((tag) => (
                      <span class="text-[10px] uppercase tracking-wider text-neutral-500 font-mono bg-cold-white px-2 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        </div>
      ))}

      {articles.length === 0 && (
        <div class="text-center py-16 text-neutral-500">
          <p>No knowledge base articles published yet.</p>
        </div>
      )}
    </div>
  </section>

  <section class="bg-cold-white py-16">
    <div class="max-w-3xl mx-auto px-6 md:px-10 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-brand-dark mb-4">Need application-specific guidance?</h2>
      <p class="text-neutral-700 mb-8">
        Our application engineers will help you specify the right battery, calculate system sizing, or evaluate cross-references for your project.
      </p>
      <a href="/contact" class="inline-flex items-center gap-2 bg-brand-gold text-brand-dark px-8 py-3 font-bold text-sm tracking-widest uppercase rounded-sm hover:brightness-110 transition">
        Contact Engineering
      </a>
    </div>
  </section>
</BaseLayout>
