---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex>
  <section class="bg-brand-dark min-h-[70vh] flex items-center relative overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero/hero-factory.webp" alt="" class="w-full h-full object-cover opacity-85" width="2000" height="1000" />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/90 via-brand-dark/40 to-brand-dark/15"></div>
    </div>

    <div class="relative z-10 max-w-screen-xl mx-auto px-6 md:px-10 py-20 w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-gold font-mono text-xs tracking-[0.3em] uppercase mb-6">404 · Page Not Found</p>
          <h1 class="text-white text-5xl md:text-7xl font-bold leading-tight tracking-tight mb-6">
            That page didn't crank.
          </h1>
          <p class="text-[#bbc7df] text-lg leading-relaxed mb-10 max-w-xl">
            The page you were looking for doesn't exist or has been moved. Try one of the popular destinations below, or use the search-by-category navigation.
          </p>

          <div class="flex flex-wrap gap-4 mb-10">
            <a href="/" class="bg-brand-gold text-brand-dark px-6 py-3 font-bold text-sm uppercase tracking-widest rounded-sm hover:brightness-110 transition">
              Back to Home
            </a>
            <a href="/products" class="bg-transparent border border-white/30 text-white px-6 py-3 font-medium text-sm uppercase tracking-widest rounded-sm hover:bg-white/5 transition">
              Browse Products
            </a>
          </div>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-sm p-8 backdrop-blur-sm">
          <p class="text-xs font-bold uppercase tracking-widest text-brand-gold mb-5">Popular Destinations</p>
          <ul class="space-y-3">
            {[
              { label: 'AGM Batteries', href: '/products/agm-batteries/' },
              { label: 'EFB Batteries', href: '/products/efb-batteries/' },
              { label: 'Heavy-Duty Batteries', href: '/products/heavy-duty-batteries/' },
              { label: 'Marine Batteries (CCS)', href: '/products/marine-batteries/' },
              { label: 'AGM vs EFB Guide', href: '/support/agm-vs-efb/' },
              { label: 'Request a Quote', href: '/distributor-program/' },
              { label: 'About AltusVolt', href: '/about-altusvolt/' },
            ].map((link) => (
              <li>
                <a href={link.href} class="group flex items-center justify-between py-2 border-b border-white/5 hover:border-brand-gold/40 transition-colors">
                  <span class="text-white text-sm group-hover:text-brand-gold transition-colors">{link.label}</span>
                  <svg class="w-4 h-4 text-white/40 group-hover:text-brand-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
