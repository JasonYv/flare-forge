---
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { siteConfig } from '../config';
import { t, getLocaleFromUrl } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
---

<BaseLayout title="Contact Us" description="Get in touch with FlareForge Manufacturing. Request a quote, ask about OEM/ODM services, or schedule a factory visit.">
  <nav class="bg-neutral-50 border-b border-neutral-200" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-neutral-500">
        <li><a href="/" class="hover:text-primary">Home</a></li>
        <li class="text-neutral-300">/</li>
        <li class="text-neutral-800 font-medium">Contact</li>
      </ol>
    </div>
  </nav>

  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Info -->
        <div>
          <h1 class="text-4xl font-bold mb-6 text-neutral-900">{t('contact.title', locale)}</h1>
          <p class="text-lg text-neutral-600 mb-8">
            Whether you need a quote, technical consultation, or factory visit arrangement, our team is ready to help.
          </p>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-neutral-900">Email</h3>
                <p class="text-neutral-600">{siteConfig.contact.email}</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-neutral-900">Phone</h3>
                <p class="text-neutral-600">{siteConfig.contact.phone}</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-neutral-900">Address</h3>
                <p class="text-neutral-600">{siteConfig.contact.address}</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-medium text-neutral-900">Working Hours</h3>
                <p class="text-neutral-600">{siteConfig.contact.workingHours}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="bg-neutral-50 rounded-2xl p-8">
          <InquiryForm locale={locale} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
