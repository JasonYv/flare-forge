---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { t, getLocaleFromUrl } from '../i18n';

const locale = getLocaleFromUrl(Astro.url);
---

<BaseLayout
  title="Request a Quote — Contact AltusVolt"
  description="Request a quote from AltusVolt. Contact our technical sales team for industrial batteries, OEM/ODM solutions, and custom specifications. 24-hour response guarantee."
>

  <!-- Main Content Canvas -->
  <div class="w-full bg-[#f2f4f7] min-h-screen text-[#191c1e]">
    <main class="flex-grow w-full max-w-[1440px] mx-auto px-4 md:px-8 py-12 md:py-24 grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

      <!-- Left Side: Form -->
      <section class="lg:col-span-7 bg-white p-8 md:p-12 shadow-sm relative rounded-sm">
        <div class="mb-12">
          <h1 class="text-4xl md:text-[3.5rem] font-bold text-[#101c2e] tracking-tight leading-none mb-6">
            REQUEST A QUOTE
          </h1>
          <p class="text-steel text-lg max-w-2xl font-medium">
            Provide your project details below. Our technical sales team will review your specifications and respond with a comprehensive proposal.
          </p>
        </div>

        <form id="quoteForm" class="space-y-8">
          <!-- Company & Contact -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col">
              <label for="company_name" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Company Name *</label>
              <input
                type="text"
                id="company_name"
                name="company_name"
                placeholder="e.g. Acme Industrial"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col">
              <label for="contact_name" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Contact Name *</label>
              <input
                type="text"
                id="contact_name"
                name="contact_name"
                placeholder="Full Name"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Contact Details -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col">
              <label for="email" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="name@company.com"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200"
              />
            </div>
            <div class="flex flex-col">
              <label for="phone" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Phone / WhatsApp *</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+1 (555) 000-0000"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Region & Product -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col">
              <label for="country" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Region / Country *</label>
              <select
                id="country"
                name="country"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200 appearance-none font-medium cursor-pointer"
              >
                <option value="">Select Region</option>
                <option value="me">Middle East</option>
                <option value="eu">Europe</option>
                <option value="asia">Asia Pacific</option>
                <option value="na">North America</option>
                <option value="africa">Africa</option>
                <option value="sa">South America</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="flex flex-col">
              <label for="product" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Product Interest *</label>
              <select
                id="product"
                name="product"
                required
                class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200 appearance-none font-medium cursor-pointer"
              >
                <option value="">Select Product Line</option>
                <option value="agm">AGM Start-Stop Batteries</option>
                <option value="solar">Solar Storage Batteries</option>
                <option value="marine">Marine Batteries</option>
                <option value="industrial">Industrial UPS</option>
                <option value="sli">Automotive SLI</option>
                <option value="custom">Custom OEM/ODM</option>
              </select>
            </div>
          </div>

          <!-- Volume -->
          <div class="flex flex-col">
            <label for="volume" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Estimated Volume (Units/Year)</label>
            <input
              type="text"
              id="volume"
              name="volume"
              placeholder="e.g., 5,000"
              class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] font-mono outline-none transition-colors duration-200"
            />
          </div>

          <!-- Message -->
          <div class="flex flex-col">
            <label for="message" class="text-xs uppercase tracking-wider text-steel mb-2 font-bold font-sans">Technical Requirements / Message</label>
            <textarea
              id="message"
              name="message"
              placeholder="Please detail specific voltage, capacity, or form factor requirements..."
              rows="5"
              class="bg-[#e0e3e6]/50 border-b-2 border-transparent focus:border-brand-gold px-4 py-3 text-[#191c1e] outline-none transition-colors duration-200 resize-none"
            ></textarea>
          </div>

          <!-- Submit Action -->
          <div class="pt-4 flex flex-col md:flex-row items-center justify-between gap-6">
            <button type="submit" class="bg-brand-gold hover:bg-[#b59848] text-[#4f3d00] text-sm font-bold uppercase tracking-widest py-4 px-10 rounded-sm transition-colors flex items-center gap-3 w-full md:w-auto justify-center cursor-pointer shadow-sm">
              <span>Submit Inquiry</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </button>
            <span class="font-mono text-xs text-[#75777d]">REQ_NO: <span class="text-[#191c1e]" id="reqNo">SYS-GEN-000</span></span>
          </div>

          <!-- Form status message -->
          <div id="formStatus" class="hidden pt-4 text-center font-medium"></div>
        </form>
      </section>

      <!-- Right Side: Contact Panel -->
      <aside class="lg:col-span-5 flex flex-col gap-8 h-full">

        <!-- Information Card -->
        <div class="bg-[#101c2e] text-white p-8 md:p-12 rounded-sm h-full flex flex-col justify-between shadow-lg">
          <div class="flex flex-col gap-10">
            <div>
              <h2 class="text-2xl font-bold mb-8 text-white flex items-center gap-3 font-sans tracking-wide">
                <div class="w-1 h-6 bg-brand-gold"></div>
                GLOBAL HEADQUARTERS
              </h2>

              <div class="space-y-8">
                <!-- Location -->
                <div class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  <div>
                    <h3 class="text-xs uppercase tracking-widest text-[#bbc7df] mb-1 font-bold">Address</h3>
                    <p class="text-white leading-relaxed font-medium">{siteConfig.contact.address}</p>
                  </div>
                </div>

                <!-- Phone -->
                {siteConfig.contact.phone && (
                  <div class="flex items-start gap-4">
                    <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <div>
                      <h3 class="text-xs uppercase tracking-widest text-[#bbc7df] mb-1 font-bold">Direct Line</h3>
                      <p class="font-mono text-white text-sm">{siteConfig.contact.phone}</p>
                    </div>
                  </div>
                )}

                <!-- WhatsApp -->
                {siteConfig.social.whatsapp && (
                  <div class="flex items-start gap-4">
                    <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                    <div>
                      <h3 class="text-xs uppercase tracking-widest text-[#bbc7df] mb-1 font-bold">WhatsApp (Global Sales)</h3>
                      <p class="font-mono text-white text-sm">{siteConfig.social.whatsapp}</p>
                    </div>
                  </div>
                )}

                <!-- Email -->
                <div class="flex items-start gap-4">
                  <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  <div>
                    <h3 class="text-xs uppercase tracking-widest text-[#bbc7df] mb-1 font-bold">Email Inquiry</h3>
                    <p class="font-mono text-white text-sm">{siteConfig.contact.email}</p>
                  </div>
                </div>

                <!-- Hours -->
                <div class="flex items-start gap-4 pt-6 border-t border-white/10">
                  <svg class="w-5 h-5 text-brand-gold shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <div>
                    <h3 class="text-xs uppercase tracking-widest text-[#bbc7df] mb-1 font-bold">Business Hours (GMT+8)</h3>
                    <p class="font-mono text-white text-sm">{siteConfig.contact.workingHours}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Map Visualization -->
            <div class="relative w-full h-48 bg-[#0a111a] rounded-sm border border-white/5 overflow-hidden">
              <img
                src="/images/hero/hero-factory.webp"
                alt="World map"
                class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale mix-blend-screen"
                width="800"
                height="400"
                loading="lazy"
              />

              <!-- Map Points -->
              <div class="absolute top-[40%] left-[30%] w-2 h-2 bg-brand-gold rounded-full shadow-[0_0_10px_#c7a850]"></div>
              <span class="absolute top-[43%] left-[28%] text-[8px] font-mono text-brand-gold">GERMANY</span>

              <div class="absolute top-[50%] left-[60%] w-2 h-2 bg-brand-gold rounded-full shadow-[0_0_10px_#c7a850]"></div>
              <span class="absolute top-[53%] left-[59%] text-[8px] font-mono text-brand-gold">DUBAI</span>

              <div class="absolute top-[55%] left-[80%] w-2 h-2 bg-brand-gold rounded-full shadow-[0_0_10px_#c7a850]"></div>
              <span class="absolute top-[58%] left-[78%] text-[8px] font-mono text-brand-gold">SE ASIA</span>

              <div class="absolute top-[45%] left-[75%] w-3 h-3 bg-white rounded-full shadow-[0_0_15px_#ffffff] animate-pulse"></div>
              <span class="absolute top-[45%] left-[80%] text-[10px] font-mono text-white font-bold">CHINA, HQ</span>
            </div>
          </div>
        </div>

        <!-- Trust Indicator -->
        <div class="bg-[#f7f9fc] border border-[#e0e3e6] p-6 flex flex-col md:flex-row items-center md:items-start gap-4 rounded-sm shadow-sm text-center md:text-left">
          <svg class="w-8 h-8 text-steel shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <p class="text-sm font-medium text-steel leading-relaxed">
            Your inquiry is handled by our dedicated export team. We guarantee a response with preliminary technical documentation within <strong class="text-[#101c2e]">24 hours</strong>.
          </p>
        </div>

      </aside>
    </main>
  </div>

  <script>
    // Generate a pseudo-random request number
    const reqNo = document.getElementById('reqNo');
    if (reqNo) {
      const num = Math.floor(Math.random() * 900) + 100;
      reqNo.textContent = `AV-${new Date().getFullYear()}-${num}`;
    }

    // Form handling
    const form = document.getElementById('quoteForm') as HTMLFormElement;
    const formStatus = document.getElementById('formStatus');

    if (form && formStatus) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const data: Record<string, string> = {};
        formData.forEach((value, key) => {
          data[key] = value.toString();
        });

        // Basic validation
        const required = ['company_name', 'contact_name', 'email', 'phone', 'country', 'product'];
        const missing = required.filter(f => !data[f]);
        if (missing.length > 0) {
          formStatus.className = 'pt-4 text-center font-medium text-red-600';
          formStatus.textContent = 'Please fill in all required fields.';
          return;
        }

        // Show success (in production, this would POST to an API)
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Submitting...';
        }

        // Simulate submission delay
        await new Promise(resolve => setTimeout(resolve, 800));

        formStatus.className = 'pt-4 text-center font-medium text-green-700';
        formStatus.textContent = 'Thank you! Your inquiry has been received. Our team will contact you within 24 hours.';
        form.reset();

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = `<span>Submit Inquiry</span><svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-7-7 7 7-7 7"/></svg>`;
        }
      });
    }
  </script>

</BaseLayout>
